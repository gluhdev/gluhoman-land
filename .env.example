# =============================================================================
# Gluhoman Land — Environment Variables Template
# =============================================================================
# Copy this file to `.env.local` for local development, or set these values
# in Vercel → Project Settings → Environment Variables for production.
# Never commit `.env.local` to git.
# =============================================================================

# Public site URL (used by sitemap.ts, robots.ts and JSON-LD StructuredData).
# Must include protocol, no trailing slash.
NEXT_PUBLIC_SITE_URL=https://gluhoman.com.ua

# Telegram bot token issued by @BotFather (format: 123456789:ABCdef...).
# Used by src/app/actions/booking.ts to deliver booking requests.
TELEGRAM_BOT_TOKEN=

# Numeric chat/channel ID where booking notifications will be posted.
# For private channels the ID starts with -100. See docs/OPERATIONS.md.
TELEGRAM_CHAT_ID=

# Email delivery (optional, second channel via Resend)
RESEND_API_KEY=
BOOKING_EMAIL_FROM=Глухомань <bookings@gluhoman.com.ua>
BOOKING_EMAIL_TO=

# Plausible analytics (optional, privacy-first)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# Sentry error monitoring (optional)
# Якщо DSN не заданий, Sentry не ініціалізується — збірка і рантайм працюють як no-op.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# =============================================================================
# Phase 1: Cart + Menu Order + LiqPay
# =============================================================================

# LiqPay (https://www.liqpay.ua/ → Кабінет → Розробники → Акаунти)
# Якщо не задано — система працює в STUB-режимі (без реальної оплати, тільки UI).
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# Email сповіщення про нові замовлення (Resend).
# BOOKING_EMAIL_TO буде використовуватись як одержувач замовлень також.
ORDERS_EMAIL_FROM="Глухомань <orders@gluhoman.com.ua>"
ORDERS_EMAIL_TO=

# =============================================================================
# Production stack (docker-compose.prod.yml) — see docs/PRODUCTION.md
# =============================================================================

# PostgreSQL (production)
POSTGRES_USER=gluhoman
POSTGRES_PASSWORD=
POSTGRES_DB=gluhoman

# Redis (production)
REDIS_URL=redis://redis:6379

# Bot (separate Telegraf process)
BOT_TOKEN=
ADMIN_CHAT_IDS=

# =============================================================================
# Admin authentication (NextAuth v5 / Auth.js)
# =============================================================================
# Admin (change for production!)
ADMIN_EMAIL=admin@gluhoman.com.ua
# Generate: openssl rand -base64 24
ADMIN_PASSWORD=

# NextAuth — generate via: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=https://gluhoman.com.ua
